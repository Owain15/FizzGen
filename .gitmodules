[submodule "FizzGen/vendor/spdlog"]
	path = FizzGen/vendor/spdlog
	url = https://github.com/gabime/spdlog
[submodule "FizzGen/vendor/GLFW"]
	path = FizzGen/vendor/GLFW
	url = https://github.com/TheCherno/glfw
	ignore = dirty
[submodule "FizzGen/vendor/ImGui"]
	path = FizzGen/vendor/ImGui
	url = https://github.com/ocornut/imgui.git
	branch = docking
	ignore = untracked
[submodule "FizzGen/vendor/glm"]
	path = FizzGen/vendor/glm
	url = http://github.com/g-truc/glm
